<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="10dp"
    android:paddingBottom="8dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:background="@drawable/bg_bottom_item"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <ImageView
        android:id="@+id/iv_bottom_icon"
        android:layout_width="@dimen/bottom_icon_size"
        android:layout_height="@dimen/bottom_icon_size"
        android:background="@drawable/bg_bottom_icon"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:contentDescription="icon" />

    <TextView
        android:id="@+id/tv_bottom_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_light_blue"
        android:textSize="@dimen/bottom_text_size"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:maxLines="1" />

</LinearLayout>
